# OneClaw 环境变量示例（复制为 .env 后按需修改；勿将含密钥的 .env 提交版本库）

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen2.5:3b
OLLAMA_STREAMING=false
OLLAMA_TEMPERATURE=0.3
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_REPEAT_PENALTY=1.2
OLLAMA_NUM_PREDICT=512

# --- Gateway ---
PORT=3000
BIND_HOST=127.0.0.1
WEBCHAT_TOKEN=

# 界面语言：zh（中文）或 en（英文）；影响 TUI、Web 默认语言、对话摘要提示语等
# ONECLAW_UI_LOCALE=zh

# --- 数据与目录（默认 ~/.oneclaw 亦可）---
# ONECLAW_DATA_DIR=
# ONECLAW_USER_WORKSPACE_DIR=
# ONECLAW_SKILLS_DIR=

ONECLAW_CHAT_CONTEXT_MAX_MESSAGES=30
ONECLAW_CHAT_SUMMARIZE_THRESHOLD=20

# --- 工具与安全 ---
ONECLAW_EXEC_ENABLED=true
# ONECLAW_EXEC_TIMEOUT_MS=30000
# ONECLAW_EXEC_DENIED_PATTERNS=

# --- V4 任务：带 taskId 对话时 exec/apply_patch 是否需先人工批准（默认 true）---
# ONECLAW_TASK_HIGH_RISK_APPROVAL=true

# --- 可选：QQ 渠道 ---
# ONECLAW_QQ_BOT_ENABLED=false
# ONECLAW_QQ_BOT_API_BASE_URL=
# ONECLAW_QQ_BOT_TOKEN=

# --- 可选：定时日报 ---
# ONECLAW_DAILY_REPORT_SCHEDULE_ENABLED=false
# ONECLAW_DAILY_REPORT_SCHEDULE_HOUR=18
# ONECLAW_DAILY_REPORT_SCHEDULE_MINUTE=0

# --- 可选：MCP（优先级：ONECLAW_MCP_SERVERS_FILE 存在则读该文件 > ONECLAW_MCP_SERVERS 内联 JSON > {ONECLAW_DATA_DIR}/config/mcp-servers.json）---
# ONECLAW_MCP_SERVERS=
# ONECLAW_MCP_SERVERS_FILE=

# 任务模板扩展 JSON 路径（默认 {ONECLAW_DATA_DIR}/config/task-templates.json），亦可在 Web「工作区」编辑
