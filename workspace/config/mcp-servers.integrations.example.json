    "args": ["-y", "@modelcontextprotocol/server-brave-search"],
    "env": {
      "BRAVE_API_KEY": "REPLACE_WITH_BRAVE_SEARCH_API_KEY"
    },
    "priority": 6
  },
  {
    "id": "github",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-github"],
    "env": {
      "GITHUB_PERSONAL_ACCESS_TOKEN": "REPLACE_WITH_GITHUB_PAT"
    },
    "priority": 4
  },
  {
    "id": "sqlite",
    "command": "npx",
    "args": ["-y", "mcp-server-sqlite-npx", "REPLACE_WITH_ABSOLUTE_PATH_TO_DATABASE_DB"],
    "priority": 3
  },
  {
    "id": "puppeteer",
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
    "priority": 2
  }
